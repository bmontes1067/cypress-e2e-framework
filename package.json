{
  "name": "cypress-e2e-framework",
  "version": "1.0.0",
  "description": "E2E testing framework — Cypress 14, TypeScript, Page Object Model, Allure, CI/CD",
  "author": "Belén Montes <bmontes1067@gmail.com>",
  "license": "MIT",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "allure:generate": "allure generate cypress/allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "devDependencies": {
    "cypress": "^14.2.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "dotenv": "^16.4.7",
    "allure-cypress": "^3.2.0"
  },
  "dependencies": {
    "allure-commandline": "^2.33.0",
    "allure-js-commons": "^3.2.0"
  }
}
